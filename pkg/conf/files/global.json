{
  "model-tags": [
    {
      "model": "^claude-.*",
      "tag": "anthropic"
    },
    {
      "model": "^gpt-.*",
      "tag": "openai"
    },
    {
      "model": "^gpt-5.*",
      "tag": "codex"
    },
    {
      "model": ".*codex.*",
      "tag": "codex"
    },
    {
      "model": "^kimi.*",
      "tag": "kimi"
    },
    {
      "model": "^moonshot.*",
      "tag": "kimi"
    },
    {
      "model": ".*MiniMax.*",
      "tag": "minimax"
    },
    {
      "model": ".*-instruct$",
      "tag": "instruct"
    },
    {
      "model": ".*:latest$",
      "tag": "latest"
    }
  ],
  "tool-selection": {
    "default": {
      "vfsPatch": false,
      "vfsInsertAfterLine": false,
      "vfsReplaceLines": false
    },
    "tags": {
      "codex": {
        "vfsPatch": true,
        "vfsEdit": false,
        "vfsWrite": false,
        "vfsDelete": false
      },
      "minimax": {
        "vfsInsertAfterLine": true,
        "vfsReplaceLines": true,
        "vfsEdit": false
      }
    }
  },
  "llm-retry-max-attempts": 10,
  "llm-retry-max-backoff-seconds": 60,
  "context-compaction-threshold": 0.95,
  "shadow-paths": [
    "AGENTS.md",
    "**/AGENTS.md",
    ".agentsignore",
    "**/.agentsignore",
    ".agents/**",
    ".csw/**",
    ".cswdata/**"
  ]
}
