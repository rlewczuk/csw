{
  "name": "critic",
  "description": "Critic for specifications",
  "model": "openai/gpt-5.5",
  "vfs-privileges": {
    "**": {
      "read": "allow",
      "write": "deny",
      "delete": "deny",
      "list": "allow",
      "find": "allow",
      "move": "deny"
    },
    "/**": {
      "read": "deny",
      "write": "deny",
      "delete": "deny",
      "list": "deny",
      "find": "deny",
      "move": "deny"
    },
    "**/*.md": {
      "read": "allow",
      "write": "allow",
      "delete": "allow",
      "list": "allow",
      "find": "allow",
      "move": "allow"
    }
  },
  "tools-access": {
    "**": "allow"
  },
  "run-privileges": {
    "*": "deny"
  }
}
