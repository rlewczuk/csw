{
  "model-tags": [
    {
      "model": "^claude-.*",
      "tag": "anthropic"
    },
    {
      "model": "^gpt-.*",
      "tag": "openai"
    },
    {
      "model": ".*-instruct$",
      "tag": "instruct"
    },
    {
      "model": ".*:latest$",
      "tag": "latest"
    }
  ],
  "context-compaction-threshold": 0.95
}
